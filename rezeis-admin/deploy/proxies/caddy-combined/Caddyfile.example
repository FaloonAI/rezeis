# Caddyfile (combined) — rezeis + reiwa на одном VPS, 443-only, свой сертификат
#
# 1. Замените PANEL_DOMAIN и APP_DOMAIN на свои домены.
# 2. Сохраните как `Caddyfile` (без .example).
# 3. Положите рядом fullchain.pem + privkey.key (SAN-cert на оба домена).
# 4. docker compose up -d

{
    # Мы НЕ слушаем :80 — выключаем авто-редирект и ACME.
    auto_https disable_redirects
}

# ── Админка rezeis ───────────────────────────────────────────────────────────
https://PANEL_DOMAIN {
    tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.key
    encode zstd gzip

    # SSE realtime в админке: отключаем буферизацию.
    @sse {
        path /api/admin/events/* /api/internal/user/*/realtime/*
    }
    handle @sse {
        reverse_proxy rezeis:8000 {
            flush_interval -1
            transport http {
                read_timeout 24h
            }
        }
    }

    reverse_proxy rezeis:8000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "SAMEORIGIN"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }
}

# ── Кабинет reiwa (SPA + /api BFF, единый образ на :5000) ────────────────────
https://APP_DOMAIN {
    tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.key
    encode zstd gzip

    reverse_proxy reiwa:5000 {
        flush_interval -1
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }
}

# Чужой хост/скан по IP → пустой ответ, домены не раскрываем.
:443 {
    tls internal
    respond 444
}
